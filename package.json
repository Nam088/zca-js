{
  "name": "@nam088/zca-js",
  "version": "3.1.0",
  "description": "Unofficial Zalo API for JavaScript",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test:feat": "bun run test/feat.ts",
    "prettier": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nam088/zca-js.git"
  },
  "homepage": "https://github.com/Nam088/zca-js",
  "bugs": {
    "url": "https://github.com/Nam088/zca-js/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "chatbot",
    "zalo",
    "api"
  ],
  "author": "Nam088",
  "license": "MIT",
  "dependencies": {
    "crypto-js": "^4.2.0",
    "form-data": "^4.0.4",
    "json-bigint": "^1.0.0",
    "pako": "^2.1.0",
    "semver": "^7.6.3",
    "spark-md5": "^3.0.2",
    "tough-cookie": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "^1.1.14",
    "@types/crypto-js": "^4.2.2",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^20.14.10",
    "@types/pako": "^2.0.3",
    "@types/semver": "^7.5.8",
    "@types/spark-md5": "^3.0.4",
    "@types/ws": "^8.5.11",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.41.0"
  },
  "lint-staged": {
    "*.{js,ts}": "bunx eslint"
  }
}
